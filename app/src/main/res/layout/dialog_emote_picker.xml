<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/emote_search_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/emoteSearchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/emoteCategoryToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterAllButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/emote_cat_all" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterTwitchChannelButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/emote_cat_twitch_channel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterTwitchGlobalButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/emote_cat_twitch_global" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterSevenTvChannelButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/emote_cat_7tv_channel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterSevenTvGlobalButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/emote_cat_7tv_global" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/emoteRecycler"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginTop="8dp" />

</LinearLayout>
