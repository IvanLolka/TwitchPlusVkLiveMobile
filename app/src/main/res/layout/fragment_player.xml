<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/playerWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:background="@drawable/bg_player_overlay"
        android:orientation="vertical"
        android:padding="6dp">

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/platformToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/twitchToggleButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="72dp"
                android:text="@string/source_twitch"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/vkToggleButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="66dp"
                android:text="@string/source_vk"
                android:textSize="11sp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

</FrameLayout>
