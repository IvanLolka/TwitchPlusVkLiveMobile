<resources>
    <style name="Base.Theme.OmniStream" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_secondary</item>
        <item name="colorOnPrimary">@color/brand_on_secondary</item>
        <item name="colorSecondary">@color/brand_primary</item>
        <item name="colorOnSecondary">@color/brand_on_primary</item>
        <item name="android:windowBackground">@drawable/bg_app</item>
        <item name="materialCardViewStyle">@style/Omni.Card</item>
    </style>

    <style name="Omni.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
