<resources>
    <style name="Base.Theme.OmniStream" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_on_secondary</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorSurfaceContainer">@color/surface_variant_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="android:windowBackground">@drawable/bg_app</item>
        <item name="materialCardViewStyle">@style/Omni.Card</item>
    </style>

    <style name="Theme.OmniStream" parent="Base.Theme.OmniStream" />

    <style name="Omni.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
